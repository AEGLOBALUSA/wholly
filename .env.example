# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WHOLLY — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in your Supabase credentials
# cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Supabase Project URL (from Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key (from Settings → API)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Analytics 4 Measurement ID (optional, for web analytics)
# Get this from Google Analytics 4 property settings
EXPO_PUBLIC_GA4_ID=G-XXXXXXXXXX
